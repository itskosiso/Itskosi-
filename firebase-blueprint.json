{
  "entities": {
    "UserProgress": {
      "title": "UserProgress",
      "description": "Stores the learning progress and leaderboard stats for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Unique identifier for the user." },
        "username": { "type": "string", "description": "Public display name." },
        "points": { "type": "number", "description": "Total points earned." },
        "rank": { "type": "string", "description": "Current rank based on points." },
        "streak": { "type": "number", "description": "Current daily streak." },
        "badges": { "type": "array", "items": { "type": "string" }, "description": "List of earned badges." },
        "completedLessons": { "type": "array", "items": { "type": "string" }, "description": "IDs of completed lessons." },
        "lastActive": { "type": "string", "format": "date-time", "description": "ISO timestamp of last activity." },
        "progress": { "type": "number", "description": "Percentage of overall course completion." },
        "profilePicture": { "type": "string", "description": "URL to the user's profile picture." }
      },
      "required": ["userId", "username", "points", "rank", "lastActive"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProgress",
      "description": "Individual user progress documents."
    }
  }
}
